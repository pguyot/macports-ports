-#import <JavaRuntimeSupport/JavaRuntimeSupport.h>
+#include <sys/sysctl.h>
+#include <string.h>
+static char *JRSCopyOSVersion(void) {
+    char ver[64] = "0.0.0";
+    size_t len = sizeof(ver);
+    sysctlbyname("kern.osproductversion", ver, &len, NULL, 0);
+    return strdup(ver);
+}


